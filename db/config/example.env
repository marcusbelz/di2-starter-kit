# Copy to <env>.env (e.g. local.env) and fill in. Loaded by db/scripts/*.sh.
# This file is a committed TEMPLATE — real <env>.env files are git-ignored.

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres        # bootstrap connects as a superuser
DB_NAME=app_local       # target database, e.g. <project>_<env>

# Version recorded in schema_apply_log by deploy.sh
APP_VERSION_MAJOR=0
APP_VERSION_MINOR=1
APP_VERSION_BUILD=0
