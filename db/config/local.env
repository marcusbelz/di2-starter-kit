# local — committed throwaway environment (never real credentials).
# Used by db/scripts/*.sh, db/tests/run.sh guidance, and the CI dry-run deploy.
# Real environments (dev/int/test/prod) get their own git-ignored <env>.env.

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres        # bootstrap connects as a superuser
DB_NAME=app_local       # target database, e.g. <project>_<env>

# Version recorded in schema_apply_log by deploy.sh
APP_VERSION_MAJOR=0
APP_VERSION_MINOR=1
APP_VERSION_BUILD=0
